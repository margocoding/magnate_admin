```gitignore
# Dependencies
node_modules/

# Build outputs
dist/
build/
*.js.map
*.ts.map

# Environment variables
.env
.env.local
*.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# Coverage
coverage/
htmlcov/
.coverage

# Temporary files
*.tmp
.DS_Store
Thumbs.db

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg-info/
.eggs/

# Virtual environments
venv/
.venv/
env/
ENV/

# Testing
.pytest_cache/
.mypy_cache/
.hypothesis/

# Node.js
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Compiled JavaScript
lib/
es/
umd/

# TypeScript
*.tsbuildinfo
.next/
.nuxt/
```